{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2023": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "extends": ["eslint:recommended", "prettier"],
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "build/",
    "coverage/",
    "tools/*/index.html"
  ],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": ["error", "smart"],
    "prefer-const": "warn"
  },
  "overrides": [
    {
      "files": [
        "shared/grok-client/browser.mjs",
        "shared/x-api-client/browser.mjs",
        "shared/test-utils/**/*.js"
      ],
      "parserOptions": { "sourceType": "module" },
      "env": { "browser": true, "node": true }
    },
    {
      "files": [
        "shared/grok-client/test/**/*.js",
        "shared/x-api-client/test/**/*.js"
      ],
      "parserOptions": { "sourceType": "module" },
      "env": { "node": true, "browser": false }
    },
    {
      "files": [
        "shared/grok-client/src/**/*.js",
        "shared/x-api-client/src/**/*.js"
      ],
      "parserOptions": { "sourceType": "script" },
      "env": { "node": true, "browser": false }
    }
  ]
}
